---
// Verse-detail panel — Phase D2 of v2 plan.
//
// Receives the verse-data dict emitted by `bst emit-static` (one row
// from the chapter's `verses` array). Renders inline-expandable
// content with a tab strip: Translations · Interlinear · Cross-refs ·
// Exegesis · Places · Chronology · Slides · Song.
//
// Heavy panels (Maps, Chronology, Slides, Song) are flagged
// data-lazy and hydrate when first opened — keeps initial bundle
// small even when a chapter has hundreds of verses each carrying
// rich data.
const { verse, primaryCodes } = Astro.props;
---
<aside class="verse-panel" data-verse-id={verse.verse_id}>
  <div class="vp-tabs" role="tablist">
    <button class="vp-tab is-active" data-tab="translations" role="tab" aria-selected="true">Translations</button>
    <button class="vp-tab" data-tab="interlinear" role="tab" aria-selected="false">Interlinear</button>
    <button class="vp-tab" data-tab="xrefs" role="tab" aria-selected="false">Cross-refs</button>
    <button class="vp-tab" data-tab="exegesis" role="tab" aria-selected="false">Exegesis</button>
    <button class="vp-tab" data-tab="places" role="tab" aria-selected="false" data-lazy="true">Places</button>
    <button class="vp-tab" data-tab="chronology" role="tab" aria-selected="false" data-lazy="true">Chronology</button>
    <button class="vp-tab" data-tab="slides" role="tab" aria-selected="false" data-lazy="true">Slides</button>
    <button class="vp-tab" data-tab="song" role="tab" aria-selected="false" data-lazy="true">Song</button>
  </div>

  <!-- Translations panel (default open) -->
  <section class="vp-section is-active" data-pane="translations" role="tabpanel">
    {primaryCodes.map((code) => (
      <p class="vp-translation" data-code={code}>
        <strong class="vp-code">{code.toUpperCase()}</strong>
        <span class="vp-text">
          {verse.translations[code] ?? <em class="vp-pending">[translation not yet generated]</em>}
        </span>
      </p>
    ))}
    {verse.translations.custom_v1 && (
      <p class="vp-translation vp-custom">
        <strong class="vp-code">CUSTOM</strong>
        <span class="vp-text">{verse.translations.custom_v1}</span>
      </p>
    )}
  </section>

  <!-- Interlinear panel — Phase D3 v3: scrollable table + dynamic columns -->
  <section class="vp-section" data-pane="interlinear" role="tabpanel" hidden>
    {verse.interlinear.length > 0 ? (
      (() => {
        // Detect which optional columns have any content; hide those
        // with all-empty cells so we don't waste horizontal space.
        const has_translit = verse.interlinear.some(w => (w.transliteration || "").trim());
        const has_gloss    = verse.interlinear.some(w => (w.gloss || "").trim());
        const has_strongs  = verse.interlinear.some(w => (w.strongs || "").trim());
        const has_lemma    = verse.interlinear.some(w => (w.lemma || "").trim());
        const has_morph    = verse.interlinear.some(w => (w.morph || "").trim());
        return (
          <div class="vp-interlinear-scroll">
            <table class="vp-interlinear-table" data-lang={verse.interlinear[0]?.lang}>
              <thead>
                <tr>
                  <th class="vp-col-num">#</th>
                  <th class="vp-col-orig">Hebrew/Greek</th>
                  {has_translit && <th class="vp-col-translit">Transliteration</th>}
                  {has_strongs && <th class="vp-col-strongs">Strong's</th>}
                  {has_lemma && <th class="vp-col-lemma">Lemma</th>}
                  {has_morph && <th class="vp-col-morph">Parsing</th>}
                  {has_gloss && <th class="vp-col-gloss">Gloss</th>}
                </tr>
              </thead>
              <tbody>
                {verse.interlinear.map((w) => (
                  <tr>
                    <td class="vp-col-num">{w.position}</td>
                    <td class="vp-col-orig"><span class="vp-surface">{w.surface}</span></td>
                    {has_translit && <td class="vp-col-translit"><em>{w.transliteration}</em></td>}
                    {has_strongs && (
                      <td class="vp-col-strongs">
                        {w.strongs ? <code class="vp-strongs">{w.strongs}</code> : ""}
                      </td>
                    )}
                    {has_lemma && <td class="vp-col-lemma">{w.lemma}</td>}
                    {has_morph && <td class="vp-col-morph"><code>{w.morph}</code></td>}
                    {has_gloss && <td class="vp-col-gloss"><em>{w.gloss || "—"}</em></td>}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        );
      })()
    ) : (
      <p class="vp-empty">Interlinear data not yet ingested for this verse.</p>
    )}
  </section>

  <!-- Cross-references panel — Phase D3 v3 (human display + base-url fix-up) -->
  <section class="vp-section" data-pane="xrefs" role="tabpanel" hidden>
    {verse.cross_refs.length > 0 ? (
      <ul class="vp-xrefs">
        {verse.cross_refs.map((x) => (
          <li>
            {x.href
              ? <a class="vp-xref-link" data-href={x.href}>{x.display}</a>
              : <span class="vp-xref-bare">{x.display}</span>
            }
          </li>
        ))}
      </ul>
    ) : (
      <p class="vp-empty">No cross-references indexed yet for this verse.</p>
    )}
  </section>

  <!-- Exegesis panel — Phase G2: per-phase sub-tabs -->
  <section class="vp-section" data-pane="exegesis" role="tabpanel" hidden>
    {verse.exegesis_sections && verse.exegesis_sections._split_error ? (
      <div class="vp-banner vp-banner-yellow">
        Exegesis available but could not be split: {verse.exegesis_sections._split_error}
      </div>
    ) : verse.exegesis_sections ? (
      <div class="vp-exegesis-tabs">
        <nav class="vp-exegesis-subtabs" role="tablist" aria-label="Exegesis phases">
          {[
            ["phase_a_text", "A · The Text"],
            ["phase_b_thesis", "B · Thesis"],
            ["phase_c_big_picture", "C · Big Picture"],
            ["phase_d_setting", "D · Setting"],
            ["phase_e_verse_craft", "E · Verse Craft"],
            ["phase_f_canonical", "F · Canonical"],
            ["phase_g_applications", "G · Applications"],
            ["memory_anchor", "Memory Anchor"],
            ["devotional_summary", "Devotional"],
            ["retention_quiz", "Quiz"],
          ].filter(([k]) => verse.exegesis_sections[k]).map(([k, label], i) => (
            <button
              class={`vp-subtab${i === 0 ? " is-active" : ""}`}
              data-subtab={k}
              role="tab"
              aria-selected={i === 0}
            >{label}</button>
          ))}
        </nav>
        {[
          "phase_a_text", "phase_b_thesis", "phase_c_big_picture",
          "phase_d_setting", "phase_e_verse_craft", "phase_f_canonical",
          "phase_g_applications", "memory_anchor", "devotional_summary", "retention_quiz",
        ].filter((k) => verse.exegesis_sections[k]).map((k, i) => {
          const html_key = k + "_html";
          return (
            <article class={`vp-exegesis-md vp-subpane${i === 0 ? " is-active" : ""}`} data-subpane={k} hidden={i !== 0}>
              {verse.exegesis_sections[html_key]
                ? <div class="vp-md-rendered" set:html={verse.exegesis_sections[html_key]} />
                : <pre class="vp-md-source">{verse.exegesis_sections[k]}</pre>
              }
            </article>
          );
        })}
        <details class="vp-audit-toggle">
          <summary>Show audit metadata (Pre-Output Scorecard, Pipeline Coherence Check, Slide Deck Sidecar, Cover Art Prompts)</summary>
          {Object.entries(verse.exegesis_sections._audit || {})
            .filter(([k, v]) => v && !k.endsWith("_html"))
            .map(([k, v]) => {
              const html_key = k + "_html";
              const html = verse.exegesis_sections._audit[html_key];
              return (
                <article class="vp-audit-section" data-audit={k}>
                  <h4>{k.replace(/_/g, " ")}</h4>
                  {html
                    ? <div class="vp-md-rendered" set:html={html} />
                    : <pre class="vp-md-source">{v}</pre>
                  }
                </article>
              );
            })}
        </details>
      </div>
    ) : verse.exegesis_md ? (
      <div class="vp-exegesis-md">
        <pre class="vp-md-source">{verse.exegesis_md}</pre>
      </div>
    ) : (
      <p class="vp-empty">
        Exegesis not yet generated for this verse. Generate one with the
        BibleStudyTool chat-thread workflow, then run <code>bst emit-static --include-exegesis</code>
        to fold it in.
      </p>
    )}
  </section>

  <!-- Places panel (lazy: hydrates when tab clicked) -->
  <section class="vp-section" data-pane="places" role="tabpanel" hidden>
    {verse.places.length > 0 ? (
      <>
        <div class="vp-map" id={`map-${verse.verse_id}`} data-places={JSON.stringify(verse.places)}></div>
        <ul class="vp-places-list">
          {verse.places.map((p) => (
            <li>
              <strong>{p.primary_name}</strong>
              {p.modern_name && <span class="vp-modern"> · modern: {p.modern_name}</span>}
              {p.alt_names.length > 0 && (
                <span class="vp-alt"> · also called {p.alt_names.join(", ")}</span>
              )}
            </li>
          ))}
        </ul>
      </>
    ) : (
      <p class="vp-empty">No places mentioned in this verse.</p>
    )}
  </section>

  <!-- Chronology panel (lazy) -->
  <section class="vp-section" data-pane="chronology" role="tabpanel" hidden>
    {verse.chronology.length > 0 ? (
      <div class="vp-timeline" data-events={JSON.stringify(verse.chronology)}>
        <ul>
          {verse.chronology.map((e) => (
            <li class={`vp-event vp-era-${e.era}`}>
              <span class="vp-year">
                {e.bc_ad_year !== null && e.bc_ad_year !== undefined
                  ? `${Math.abs(e.bc_ad_year)} ${e.bc_ad_year < 0 ? "BC" : "AD"}`
                  : "—"}
              </span>
              <span class="vp-event-name">{e.event}</span>
              <span class="vp-certainty" title={e.era}>[{e.certainty}]</span>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <p class="vp-empty">No chronology events linked to this verse.</p>
    )}
  </section>

  <!-- Slides panel (lazy) -->
  <section class="vp-section" data-pane="slides" role="tabpanel" hidden>
    {verse.slides && verse.slides.length > 0 ? (
      <div class="vp-slides-grid">
        {verse.slides.map((s) => (
          <a href={s.full_url} class="vp-slide-thumb" target="_blank" rel="noopener">
            <img src={s.thumb_url} alt={s.title} loading="lazy" />
            <span class="vp-slide-title">{s.title}</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="vp-empty">
        No slides generated yet. Run a slide deck via BibleStudyTool's
        Workflow page for this passage.
      </p>
    )}
  </section>

  <!-- Song panel (lazy) -->
  <section class="vp-section" data-pane="song" role="tabpanel" hidden>
    {verse.song ? (
      <div class="vp-song">
        <pre class="vp-lyrics">{verse.song.lyrics}</pre>
        {verse.song.style && <p class="vp-style"><strong>Style:</strong> {verse.song.style}</p>}
        <button class="vp-suno-copy" data-target={`vp-lyrics-${verse.verse_id}`}>Copy lyrics</button>
      </div>
    ) : (
      <p class="vp-empty">
        No song generated yet. Run the song flow in BibleStudyTool, then
        re-emit this chapter.
      </p>
    )}
  </section>
</aside>
