---
import "../styles/global.css";
const { title = "BibleStudy" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Derive a passage breadcrumb from the URL so the top bar reflects
// the chapter the reader is currently viewing instead of a hardcoded
// link. Pattern: /<base>/<book-slug>/<chapter>/
const path = Astro.url.pathname.replace(base, "").replace(/^\/+/, "");
const m = path.match(/^([a-z0-9-]+)\/(\d+)\/?/i);
const breadcrumbBook = m ? m[1] : "";
const breadcrumbChapter = m ? m[2] : "";
const breadcrumbDisplay = breadcrumbBook
  ? breadcrumbBook
      .split("-")
      .map(w => /^\d+$/.test(w) ? w : w[0].toUpperCase() + w.slice(1))
      .join(" ") + " " + breadcrumbChapter
  : "";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%238b6f3f'%3E%3Cpath d='M19 2H8C6.9 2 6 2.9 6 4v16c0 1.1.9 2 2 2h11V2zm-2 16H8V4h9v14z'/%3E%3C/svg%3E" />
  <script is:inline define:vars={{ base }}>
    window.__BS_BASE = base;
  </script>
</head>
<body>
  <header class="topbar">
    <a href={`${base}/`} class="brand">BibleStudy</a>
    {breadcrumbDisplay && (
      <span class="breadcrumb">
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-passage">{breadcrumbDisplay}</span>
      </span>
    )}
    <nav>
      <button class="topbar-btn cmdk-trigger" type="button" title="Open passage palette (Cmd+K) — type any book + chapter+verse"
              onclick="window.dispatchEvent(new KeyboardEvent('keydown', {key:'k', metaKey:true}))">
        <span class="cmdk-label">Jump to passage</span>
        <span class="cmdk-shortcut">⌘K</span>
      </button>
      <a class="topbar-btn" href={`${base}/`} title="All books and chapters">📖 Books</a>
      <a class="topbar-btn" href={`${base}/settings/`} title="Settings">⚙</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer class="footer">
    BibleStudy · custom LLM-generated translation · Hebrew/Greek interlinear from open public-domain sources ·
    cross-references CC-BY OpenBible.info · chronology Ussher 1658 (PD).
    <br />
    Hosted on GitHub Pages + Cloudflare Pages from <a href="https://github.com/davidlary/BibleStudy">davidlary/BibleStudy</a>.
  </footer>
  <script is:inline src={`${base}/js/biblestudy.js`}></script>
</body>
</html>
<style>
  .breadcrumb {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--ink-muted);
    margin-left: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .breadcrumb-sep {
    color: var(--rule);
    font-size: 1rem;
  }
  .breadcrumb-passage {
    color: var(--ink);
    font-weight: 500;
  }
  .topbar-btn {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-muted);
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
    font-family: var(--sans);
    font-size: 0.85rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .topbar-btn:hover {
    color: var(--ink);
    border-color: var(--accent);
    text-decoration: none;
  }
  .cmdk-shortcut {
    font-family: var(--mono);
    font-size: 0.72rem;
    background: var(--bg-elev);
    padding: 0.05rem 0.3rem;
    border-radius: 3px;
    color: var(--ink-muted);
  }
  @media (max-width: 640px) {
    .cmdk-label { display: none; }
    .topbar-btn { padding: 0.25rem 0.45rem; }
    .breadcrumb { display: none; }  /* avoid wrap */
  }
</style>
