    "heading": "Reporting What God Had Done",
    "source": "biblestudy-curated-v1"
  }
];
const primaryCodes = ["asv", "bsb", "kjv"];
const primary = primaryCodes[0];

// Phase H3: group verses by pericope. Returns
// [{ heading, verses: [verseObjects...] }, ...] where heading is
// "" for any verse range that has no pericope row (we still render
// the verses, just without a heading).
function groupByPericope(allVerses, allPericopes) {
  if (!allPericopes || allPericopes.length === 0) {
    return [{ heading: "", verses: allVerses }];
  }
  const groups = [];
  let cursor = 0;
  for (const peri of allPericopes) {
    while (cursor < allVerses.length && allVerses[cursor].verse_num < peri.verse_start) {
      if (groups.length === 0 || groups[groups.length - 1].heading !== "") {
        groups.push({ heading: "", verses: [] });
      }
      groups[groups.length - 1].verses.push(allVerses[cursor]);
      cursor++;
    }
    const peri_group = { heading: peri.heading, peri_id: peri.id, verses: [] };
    while (cursor < allVerses.length && allVerses[cursor].verse_num <= peri.verse_end) {
      peri_group.verses.push(allVerses[cursor]);
      cursor++;
    }
    if (peri_group.verses.length > 0) groups.push(peri_group);
  }
  while (cursor < allVerses.length) {
    if (groups.length === 0 || groups[groups.length - 1].heading !== "") {
      groups.push({ heading: "", verses: [] });
    }
    groups[groups.length - 1].verses.push(allVerses[cursor]);
    cursor++;
  }
  return groups;
}

const pericope_groups = groupByPericope(verses, pericopes);
---
<Base title="Acts 14 · BibleStudy">
  <h1>Acts 14</h1>
  <p class="provenance">
    Translations:&nbsp;<span class="provenance-active">{primary.toUpperCase()}</span> · alternates:&nbsp;{primaryCodes.slice(1).join(' · ')} ·
    custom LLM translation arrives once generated by BibleStudyTool. ·
    press <kbd>1</kbd>/<kbd>2</kbd>/<kbd>3</kbd> to swap; <kbd>c</kbd> to compare.
  </p>
  <script is:inline define:vars={{ codes: primaryCodes }}>
    window.__bs_primaryCodes = codes;
  </script>
  <div class="chapter-body">
    {pericope_groups.map((group) => (
      <section class="pericope" data-peri-id={group.peri_id || ""}>
        {group.heading && <h3 class="pericope-heading">{group.heading}</h3>}
        <div class="pericope-body">
          {group.verses.map((v) => (
            <>
              <span class="verse" id={`v${v.verse_num}`} data-verse-id={v.verse_id} data-translations={JSON.stringify(v.translations)}>
                <a href={`#v${v.verse_num}`} class="verse-num" aria-expanded="false" aria-controls={`panel-${v.verse_id}`}>{v.verse_num}</a>
                <span class="verse-text">{
                  // Show the primary code's text; if that's null/missing,
                  // fall back to the first non-null translation we have
                  // (so we never show "[translation pending]" when SOME
                  // translation is loaded). Only when nothing is loaded
                  // do we show the placeholder.
                  v.translations[primary] ??
                    (Object.values(v.translations).find(t => t) ??
                      <em>[translation pending]</em>)
                }</span>{" "}
              </span>
              <VersePanel verse={v} primaryCodes={primaryCodes} />
            </>
          ))}
        </div>
      </section>
    ))}
  </div>
</Base>
