---
<Base title="Genesis 1 · BibleStudy">
  <h1>Genesis 1</h1>
  <p class="provenance">
    Translations:&nbsp;<span class="provenance-active">{primary.toUpperCase()}</span> · alternates:&nbsp;{primaryCodes.slice(1).join(' · ')} ·
    custom LLM translation arrives once generated by BibleStudyTool. ·
    press <kbd>1</kbd>/<kbd>2</kbd>/<kbd>3</kbd> to swap; <kbd>c</kbd> to compare.
  </p>
  <script is:inline define:vars={{ codes: primaryCodes }}>
    window.__bs_primaryCodes = codes;
  </script>
  <div class="chapter-body">
    {verses.map((v) => (
      <>
        <span class="verse" id={`v${v.verse_num}`} data-verse-id={v.verse_id} data-translations={JSON.stringify(v.translations)}>
          <a href={`#v${v.verse_num}`} class="verse-num" aria-expanded="false" aria-controls={`panel-${v.verse_id}`}>{v.verse_num}</a>
          <span class="verse-text">{v.translations[primary] ?? <em>[translation pending]</em>}</span>{" "}
        </span>
        <VersePanel verse={v} primaryCodes={primaryCodes} />
      </>
    ))}
  </div>
</Base>
<style is:inline>
  kbd {
    display: inline-block;
    border: 1px solid var(--rule);
    background: var(--bg-elev);
    padding: 0 0.3rem;
    border-radius: 3px;
    font-family: var(--mono);
    font-size: 0.75rem;
  }
</style>
