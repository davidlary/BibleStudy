---
import Base from "../layouts/Base.astro";

const allTranslations = [
    { code: "asv", label: "ASV (1901, public domain)" },
    { code: "bsb", label: "BSB (Berean Standard Bible, CC0)" },
    { code: "kjv", label: "KJV (1611, public domain)" },
    { code: "web", label: "WEB (World English Bible, CC0)" },
    { code: "darby", label: "Darby (1890, public domain)" },
    { code: "ylt", label: "Young's Literal (1862, public domain)" },
    { code: "webster", label: "Webster (1833, public domain)" },
    { code: "geneva", label: "Geneva (1599, public domain)" },
    { code: "erv", label: "ERV (1885, public domain)" },
    { code: "custom_v1", label: "Custom (LLM-generated, this project)" },
];
---
<Base title="Settings · BibleStudy">
  <h1>Settings</h1>
  <p class="provenance">
    Stored in your browser via <code>localStorage</code>. Settings persist
    across sessions on this device. Reset cleared by clearing site data.
  </p>

  <h2>Translations</h2>
  <p>Pick up to <strong>3</strong> translations to show on every chapter page. The first one is the primary (main reading); the others are accessible via the compare drawer (press <kbd>c</kbd>) or the keyboard shortcuts <kbd>1</kbd> / <kbd>2</kbd> / <kbd>3</kbd>.</p>
  <form id="trans-form" class="settings-form">
    <ul class="trans-list">
      {allTranslations.map((t) => (
        <li>
          <label>
            <input type="checkbox" name="codes" value={t.code} />
            <span>{t.label}</span>
          </label>
        </li>
      ))}
    </ul>
    <p class="meta" id="trans-meta"></p>
  </form>

  <h2>Theme</h2>
  <form id="theme-form" class="settings-form">
    <label><input type="radio" name="theme" value="auto" checked> Auto (follow system)</label><br/>
    <label><input type="radio" name="theme" value="light"> Light (warm paper)</label><br/>
    <label><input type="radio" name="theme" value="dark"> Dark (deep slate)</label>
  </form>

  <h2>Reading mode</h2>
  <form id="mode-form" class="settings-form">
    <label><input type="radio" name="mode" value="generous" checked> Generous — wider column, larger type</label><br/>
    <label><input type="radio" name="mode" value="compact"> Compact — narrower column, denser layout</label>
  </form>

  <h2>Default panels</h2>
  <p>Which Detail panels open automatically when you click a verse:</p>
  <form id="panel-form" class="settings-form">
    <label><input type="checkbox" name="panel" value="translations" checked> Translations</label><br/>
    <label><input type="checkbox" name="panel" value="interlinear"> Interlinear</label><br/>
    <label><input type="checkbox" name="panel" value="xrefs"> Cross-refs</label><br/>
    <label><input type="checkbox" name="panel" value="exegesis"> Exegesis</label>
  </form>

  <h2>Default exegesis sub-tab</h2>
  <p>When you click a verse, the Exegesis panel opens at this sub-tab by default. Switching tabs once you're in the panel stays the same.</p>
  <form id="phase-form" class="settings-form">
    <label><input type="radio" name="phase" value="phase_a_text" checked> A · The Text</label><br/>
    <label><input type="radio" name="phase" value="phase_b_thesis"> B · Thesis</label><br/>
    <label><input type="radio" name="phase" value="phase_c_big_picture"> C · Big Picture</label><br/>
    <label><input type="radio" name="phase" value="phase_d_setting"> D · Setting</label><br/>
    <label><input type="radio" name="phase" value="phase_e_verse_craft"> E · Verse Craft</label><br/>
    <label><input type="radio" name="phase" value="phase_f_canonical"> F · Canonical Connection</label><br/>
    <label><input type="radio" name="phase" value="phase_g_applications"> G · Applications</label><br/>
    <label><input type="radio" name="phase" value="memory_anchor"> Memory Anchor</label><br/>
    <label><input type="radio" name="phase" value="devotional_summary"> Devotional Summary</label>
  </form>

  <h2>Audit metadata</h2>
  <form id="audit-form" class="settings-form">
    <label><input type="checkbox" name="audit_default_open"> Auto-expand audit metadata (Pre-Output Scorecard, Pipeline Coherence Check, Slide Deck Sidecar, Cover Art Prompts)</label><br/>
    <p class="meta">Power-user override: append <code>?audit=1</code> to any chapter URL to expand audit metadata for that visit only.</p>
  </form>

  <h2>Pericope headings</h2>
  <p>Pericopes are literary units (paragraphs) within a chapter. Headings are hand-curated per <a href="https://github.com/davidlary/BibleStudyTool/blob/main/docs/PERICOPE_HEADING_STYLE.md">our 6-rule style guide</a> — divine agency foregrounded, no speculation, ≤8 words, echoing the inspired text.</p>
  <form id="pericope-form" class="settings-form">
    <label><input type="checkbox" name="pericope_show" checked> Show pericope headings on chapter pages</label>
  </form>

  <h2>LLM provider</h2>
  <p>The Settings record what the BibleStudyTool authoring side should use when generating new exegeses + translations. The static site itself does not call any LLM.</p>
  <form id="llm-form" class="settings-form">
    <label><input type="radio" name="llm" value="gemini" checked> Gemini 2.5 Pro (cloud, ~$1/verse)</label><br/>
    <label><input type="radio" name="llm" value="ollama"> Ollama (local, free, ~free runtime)</label>
  </form>

  <p style="margin-top: 2rem;">
    <button id="reset-btn" type="button" class="settings-btn">Reset to defaults</button>
  </p>

  <script is:inline>
    (function () {
      const KEY = "biblestudy.settings.v1";
      const DEFAULTS = {
        codes: ["asv", "bsb", "kjv"],
        theme: "auto",
        mode: "generous",
        panels: ["translations"],
        llm: "gemini",
        phase: "phase_a_text",
        audit_default_open: false,
        pericope_show: true,
      };
      function load() {
        try { return Object.assign({}, DEFAULTS, JSON.parse(localStorage.getItem(KEY) || "{}")); } catch { return DEFAULTS; }
      }
      function save(s) { localStorage.setItem(KEY, JSON.stringify(s)); }

      function applyToForm() {
        const s = load();
        document.querySelectorAll('input[name="codes"]').forEach(i => { i.checked = s.codes.includes(i.value); });
        document.querySelectorAll('input[name="theme"]').forEach(i => { i.checked = (i.value === s.theme); });
        document.querySelectorAll('input[name="mode"]').forEach(i => { i.checked = (i.value === s.mode); });
        document.querySelectorAll('input[name="panel"]').forEach(i => { i.checked = s.panels.includes(i.value); });
        document.querySelectorAll('input[name="llm"]').forEach(i => { i.checked = (i.value === s.llm); });
        document.querySelectorAll('input[name="phase"]').forEach(i => { i.checked = (i.value === s.phase); });
        document.querySelectorAll('input[name="audit_default_open"]').forEach(i => { i.checked = !!s.audit_default_open; });
        document.querySelectorAll('input[name="pericope_show"]').forEach(i => { i.checked = s.pericope_show !== false; });
        updateMeta();
      }

      function updateMeta() {
        const checked = Array.from(document.querySelectorAll('input[name="codes"]:checked')).map(i => i.value);
        const meta = document.getElementById('trans-meta');
        meta.textContent = `Selected: ${checked.length} / 3 — ${checked.join(', ') || '(none)'}`;
        meta.style.color = checked.length > 3 ? '#c44' : 'var(--ink-muted)';
      }

      function readForms() {
        const codes = Array.from(document.querySelectorAll('input[name="codes"]:checked')).map(i => i.value);
        if (codes.length > 3) {
          // Trim from the end; warn the user.
          while (codes.length > 3) {
            const last = codes.pop();
            const inp = document.querySelector(`input[name="codes"][value="${last}"]`);
            if (inp) inp.checked = false;
          }
        }
        const theme = (document.querySelector('input[name="theme"]:checked') || {}).value || 'auto';
        const mode = (document.querySelector('input[name="mode"]:checked') || {}).value || 'generous';
        const panels = Array.from(document.querySelectorAll('input[name="panel"]:checked')).map(i => i.value);
        const llm = (document.querySelector('input[name="llm"]:checked') || {}).value || 'gemini';
        const phase = (document.querySelector('input[name="phase"]:checked') || {}).value || 'phase_a_text';
        const audit_default_open = !!(document.querySelector('input[name="audit_default_open"]') || {}).checked;
        const pericope_show = !!(document.querySelector('input[name="pericope_show"]') || {}).checked;
        return { codes, theme, mode, panels, llm, phase, audit_default_open, pericope_show };
      }

      document.querySelectorAll('input').forEach(i => i.addEventListener('change', () => {
        save(readForms());
        updateMeta();
        // Theme apply immediately
        const s = readForms();
        document.documentElement.dataset.theme = (s.theme === 'auto' ? '' : s.theme);
      }));

      document.getElementById('reset-btn').addEventListener('click', () => {
        if (confirm('Reset all settings to defaults?')) {
          localStorage.removeItem(KEY);
          applyToForm();
        }
      });

      applyToForm();
    })();
  </script>
</Base>
<style is:inline>
  .settings-form { font-family: var(--sans); font-size: 0.92rem; }
  .settings-form label { line-height: 1.8; }
  .trans-list { list-style: none; padding: 0; columns: 2; column-gap: 1.5rem; }
  .trans-list li { break-inside: avoid; padding: 0.15rem 0; }
  kbd {
    display: inline-block;
    border: 1px solid var(--rule);
    background: var(--bg-elev);
    padding: 0.05rem 0.3rem;
    border-radius: 3px;
    font-family: var(--mono);
    font-size: 0.78rem;
  }
  .settings-btn {
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    color: var(--ink);
    padding: 0.4rem 0.9rem;
    border-radius: 4px;
    font-family: var(--sans);
    font-size: 0.85rem;
    cursor: pointer;
  }
  .settings-btn:hover { background: var(--bg); border-color: var(--accent); }
</style>
